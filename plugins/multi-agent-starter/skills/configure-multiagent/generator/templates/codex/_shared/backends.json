{
  "schema_version": "1",
  "flavor": "codex",
  "multiagent_root_env": "MULTIAGENT_ROOT",
  "workers": {
    "claude-main": {
      "model": "host-default",
      "call_type": "cli",
      "brief_mode": "content",
      "cli": {
        "command": "claude",
        "args_template": ["-p", "@brief_content"],
        "non_interactive": { "stdin": "/dev/null", "no_tty": true, "on_permission_prompt": "fail" }
      },
      "cwd_policy": "isolated_tmp",
      "write_policy": "none",
      "approval_class": "worker",
      "result_capture": "envelope",
      "timeout": 300
    },
    "codex-main": {
      "model": "codex-default",
      "call_type": "native",
      "native": { "subagent_type": "codex-main", "prompt_source": "brief", "model_alias": "codex-default" },
      "approval_class": "worker",
      "result_capture": "orchestrator"
    },
    "codex-critic": {
      "model": "codex-default",
      "call_type": "native",
      "native": { "subagent_type": "codex-critic", "prompt_source": "brief", "model_alias": "codex-default" },
      "approval_class": "worker",
      "result_capture": "orchestrator",
      "write_policy": "none"
    },
    "gemini": {
      "model": "gemini-3.1-pro-high",
      "call_type": "cli",
      "brief_mode": "content",
      "cli": {
        "command": "agy",
        "args_template": ["-p", "@brief_content"],
        "non_interactive": { "stdin": "/dev/null", "no_tty": true, "on_permission_prompt": "fail" }
      },
      "cwd_policy": "isolated_tmp",
      "write_policy": "none",
      "approval_class": "worker",
      "result_capture": "envelope",
      "timeout": 300,
      "fallbacks": [
        {
          "model": "gemini-3.1-pro-high", "call_type": "api", "timeout": 300,
          "approval_class": "worker", "result_capture": "envelope",
          "api": { "ref": "adapters/gemini_api.sh", "required_env": ["GEMINI_API_KEY"],
                   "brief_pass": "arg1", "retry": { "max": 2, "backoff_s": 2 } }
        }
      ]
    }
  }
}
